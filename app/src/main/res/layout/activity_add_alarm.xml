<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- HEADER -->
    <include layout="@layout/layout_header"/>

    <!-- CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Input Waktu - Menggunakan TextView dengan style seperti input -->
        <TextView
            android:id="@+id/tv_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="@android:drawable/editbox_background"
            android:drawableRight="@android:drawable/ic_menu_edit"
            android:drawablePadding="8dp"
            android:text="--:--"
            android:textSize="16sp"
            android:textColor="#000000"
            android:clickable="true"
            android:focusable="true"
            android:hint="Pilih Waktu"
            android:gravity="start|center_vertical"/>

        <!-- Input Label -->
        <EditText
            android:id="@+id/et_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Label Alarm"
            android:padding="12dp"
            android:layout_marginTop="16dp"
            android:background="@android:drawable/editbox_background"/>

        <!-- Tombol Simpan -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#628141"
            android:text="Simpan"
            android:layout_marginTop="24dp"
            android:padding="12dp"/>

        <!-- Tombol Batal -->
        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#628141"
            android:text="Batal"
            android:layout_marginTop="12dp"
            android:padding="12dp"/>

        <!-- Tombol Kembali -->
        <Button
            android:id="@+id/btn_back"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#628141"
            android:text="Kembali"
            android:layout_marginTop="12dp"
            android:padding="12dp"/>

    </LinearLayout>

    <!-- FOOTER -->
    <include layout="@layout/layout_footer"/>

</LinearLayout>