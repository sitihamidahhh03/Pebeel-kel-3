<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_bottom_sheet">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="#DDDDDD"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verifikasi Keamanan"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/syam_green_dark"
        android:layout_gravity="center" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Geser kepingan puzzle ke posisi yang benar"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginTop="8dp"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutPuzzleContainer"
        android:layout_width="280dp"
        android:layout_height="160dp"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/ivPuzzleBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/pemandangan_1"
            android:scaleType="centerCrop" />

        <!-- Target Slot (Lubang Hitam Transparan) -->
        <ImageView
            android:id="@+id/ivPuzzleTarget"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:src="@drawable/ic_puzzle_piece"
            app:tint="#A6000000"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Kepingan Puzzle (TANPA TINT agar gambar asli terlihat) -->
        <ImageView
            android:id="@+id/ivPuzzlePiece"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:elevation="8dp"
            app:layout_constraintTop_toTopOf="@+id/ivPuzzleTarget"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="@drawable/bg_captcha_track"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvCaptchaHintSheet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GESER PUZZLE >>>"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <SeekBar
            android:id="@+id/seekBarPuzzle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:progressDrawable="@android:color/transparent"
            android:thumb="@drawable/ic_captcha_thumb"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:splitTrack="false"
            android:max="100" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>