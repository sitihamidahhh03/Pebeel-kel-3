<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_navigation"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/logo_aplikasi"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#000000"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/header_icon"
                    android:layout_marginEnd="8dp"/>
                <ImageView
                    android:id="@+id/header_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:src="@android:drawable/ic_menu_myplaces"
                    app:tint="#000000"
                    android:contentDescription="@null"/>
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/saran_tindakan"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#000000"
                android:layout_marginBottom="16dp"/>

            <!-- Kartu Kelembaban Rendah -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F5F5F5">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/kelembaban_rendah"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:gravity="center_vertical"
                        app:drawableStartCompat="@android:drawable/ic_dialog_alert"
                        android:drawablePadding="8dp"
                        app:drawableTint="#000000"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/msg_saran_siram"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="16dp"/>
                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_gravity="center_horizontal"
                        android:text="@string/siram_tanaman"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        android:backgroundTint="#E0E0E0"
                        android:textColor="#555555"
                        app:cornerRadius="24dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Kartu Kelembaban Tinggi -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F5F5F5">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/kelembaban_tinggi"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:gravity="center_vertical"
                        app:drawableStartCompat="@android:drawable/ic_dialog_alert"
                        android:drawablePadding="8dp"
                        app:drawableTint="#000000"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/msg_kelembaban_tinggi"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="16dp"/>
                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_gravity="center_horizontal"
                        android:text="@string/tunda_penyiraman"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        android:backgroundTint="#E0E0E0"
                        android:textColor="#555555"
                        app:cornerRadius="24dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/saatnya_menyiram"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#000000"
                android:layout_marginBottom="16dp"/>

            <!-- Kartu Saatnya Menyiram (Besar) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F5F5F5">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/msg_saatnya_menyiram"
                        android:textSize="13sp"
                        android:textColor="#666666"
                        android:layout_marginBottom="20dp"/>
                    <ImageView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="center_horizontal"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:tint="#757575"
                        android:layout_marginBottom="20dp"
                        android:contentDescription="@null"/>
                    <Button
                        android:layout_width="200dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center_horizontal"
                        android:text="@string/oke"
                        android:textAllCaps="false"
                        android:backgroundTint="#E0E0E0"
                        android:textColor="#555555"
                        app:cornerRadius="24dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation Bar (Mockup) -->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal">
        <ImageView
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:src="@android:drawable/ic_menu_home"
            app:tint="#757575"
            android:contentDescription="@null"/>
        <ImageView
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="#757575"
            android:contentDescription="@null"/>
        <ImageView
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:src="@android:drawable/ic_menu_recent_history"
            app:tint="#757575"
            android:contentDescription="@null"/>
        <ImageView
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:src="@android:drawable/ic_popup_reminder"
            app:tint="#000000"
            android:contentDescription="@null"/>
    </LinearLayout>

</RelativeLayout>
